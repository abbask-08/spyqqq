# Copy this file to .env and fill in your Alpaca PAPER keys.
# Get them free: https://alpaca.markets -> sign up -> switch the dashboard
# (upper-left selector) to Paper Trading -> generate API key.
# The secret is shown ONCE — save it immediately.
#
# These must be PAPER keys. Never put live-trading keys in this file.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
